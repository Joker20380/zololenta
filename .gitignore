cat > .gitignore <<'EOF'
# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/

# venv
venv/
.venv/

# Env / secrets
.env
.env.*
*.key
*.pem

# Django
*.sqlite3
db.sqlite3
media/
staticfiles/

# Logs
*.log

# IDE
.idea/
.vscode/
EOF
/backups/
/tmp/
/zololenta/.env
/zololenta/main/views.py.broken_*
# Never commit SSH credentials
/1
/1.pub
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
